# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Pooled connection (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# ── Admin sign-in (self-contained, single admin) ─────────────────────────────
# Email + password for the one admin account. No Supabase / email needed.
ADMIN_EMAIL="office@srigujaratividhyalaya.com"
ADMIN_PASSWORD="<choose-a-strong-password>"
# Secret used to sign the admin session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="<random-32-byte-hex-string>"

# ── Cloudinary (Phase 1 media) ───────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="<cloud-name>"

# ── Resend (Phase 1 enquiry notifications) ───────────────────────────────────
RESEND_API_KEY="<resend-api-key>"
ENQUIRY_NOTIFY_EMAIL="office@srigujaratividhyalaya.com"
